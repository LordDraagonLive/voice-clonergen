DATABASE_URL=postgres://voice:voice@postgres:5432/voice_cloner?sslmode=disable
REDIS_URL=redis://redis:6379/0
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/data/audio
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=voice-cloner
INFERENCE_RPC_URL=http://inference-worker:50051
DEFAULT_MODEL=qwen3-tts
MAX_UPLOAD_MB=50
ALLOWED_AUDIO_TYPES=audio/wav,audio/mpeg,audio/mp4,audio/flac,audio/x-m4a
ENABLE_PLACEHOLDER_TTS=false
MAX_TTS_CHUNK_CHARS=350
REFERENCE_MIN_SECONDS=3
REFERENCE_MAX_SECONDS=15
QWEN_MODEL_NAME=Qwen/Qwen3-TTS-12Hz-0.6B-Base
QWEN_DEVICE_MAP=auto
QWEN_DTYPE=auto
QWEN_ATTN_IMPLEMENTATION=sdpa
QWEN_LANGUAGE=English
ENABLE_REAL_XTTS=false
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_DEVICE=auto
XTTS_LANGUAGE=en
API_PORT=8081
VITE_API_URL=http://localhost:8081
